raw_queue = queue.Queue()
parsed_queue = queue.Queue()

PERSONS = [
    "Зеленський", "Трамп", "Путін", "Байден", "Сі", "Макрон",
    "Шидлюх", "Жемчугов", "Морозов", "Аслунд", "Сталін",
    "Мономах", "Скоропадський", "Дорошенко", "Флемінг", "Карась", "Веселий"
]

TOPICS = [
    "Україна", "Росія", "США", "Китай", "НАТО", "ЄС", "Іран",
    "війна", "фронт", "наступ", "атака", "дрони", "ракети",
    "переговори", "трибунал", "полон", "окупанти", "ЗСУ"
]

def extract_headlines(raw_text):
    pattern = r'\d{4},\s\w+\s+\d+\s\w+\s+\d{2}:\d{2}\s+\w+\s+(.*?)(?=\d{4},\s\w+|\Z)'
    matches = re.findall(pattern, raw_text, re.DOTALL)
    headlines = []
    for m in matches:
        lines = m.strip().split('\n')
        for line in lines:
            line = line.strip()
            if line and not line.startswith('2026') and len(line) > 10:
                headlines.append(line)
                break
    return headlines

def find_mentions(text, items):
    found = []
    for item in items:
        if re.search(r'\b' + re.escape(item) + r'\b', text, re.IGNORECASE):
            found.append(item)
    return found

def producer(target_date):
    target_date = target_date.strip().lower()
    blocks = re.split(r'\d{4},\s\w+', raw_queue.get())
    relevant = []
    capture = False
    for block in blocks:
        if target_date in block.lower():
            capture = True
            relevant.append(block)
        elif capture and re.match(r'\d{4},\s\w+', block):
            break
        elif capture:
            relevant.append(block)
    headlines = extract_headlines('\n'.join(relevant))
    parsed_queue.put(headlines)

def consumer():
    headlines = parsed_queue.get()
    person_counter = Counter()
    topic_counter = Counter()
    for h in headlines:
        persons = find_mentions(h, PERSONS)
        topics = find_mentions(h, TOPICS)
        person_counter.update(persons)
        topic_counter.update(topics)
    print("Заголовки за вказану дату:")
    for i, h in enumerate(headlines, 1):
        print(f"{i}. {h}")
    print("\nНайчастіші особистості:")
    for p, c in person_counter.most_common(5):
        print(f"  {p}: {c}")
    print("\nНайчастіші теми:")
    for t, c in topic_counter.most_common(5):
        print(f"  {t}: {c}")

def main():
    raw_queue.put(url_content)
    target = input("Введіть дату (наприклад, 28 травня): ")
    t1 = threading.Thread(target=producer, args=(target,))
    t2 = threading.Thread(target=consumer)
    t1.start()
    t2.start()
    t1.join()
    t2.join()

if __name__ == "__main__":
    main()
